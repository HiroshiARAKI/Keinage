# Keinage environment sample
#
# The complete environment template is maintained in `.env.example`.
# These settings cover audit log retention and the maintenance cleanup job.

# Optional audit logs for security, billing, and admin operations.
AUDIT_LOG_ENABLED=true
AUDIT_LOG_IP_HASH_SECRET=
# Delete audit logs older than this many days. Unset or 0 disables cleanup.
AUDIT_LOG_RETENTION_DAYS=365

# Optional maintenance cleanup retention settings.
# The maintenance job defaults to dry-run. Use --execute to delete candidates.
MAINTENANCE_SIGNUP_RETENTION_DAYS=30
STRIPE_EVENT_RETENTION_DAYS=90
ORPHAN_MEDIA_MIN_AGE_DAYS=7
